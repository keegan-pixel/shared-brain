{
  "name": "shared-brain-vault-sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local file watcher that mirrors the Obsidian vault into the Shared Brain platform.",
  "scripts": {
    "sync:once": "tsx src/index.ts --mode=once",
    "sync:watch": "tsx src/index.ts --mode=watch",
    "sync:dry": "tsx src/index.ts --mode=once --dry-run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/pdf-parse": "^1.1.5",
    "@vercel/blob": "^2.3.3",
    "chokidar": "^4.0.3",
    "gray-matter": "^4.0.3",
    "mammoth": "^1.12.0",
    "p-limit": "^7.1.0",
    "pdf-parse": "^2.4.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
