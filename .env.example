# Copy to .env.local and fill in your own values.

# --- Neon Postgres ---
# Create at https://neon.tech, enable pgvector via `CREATE EXTENSION vector;`
# Migration script also runs this automatically.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- Clerk auth ---
# Create app at https://clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# --- MCP server ---
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
MCP_API_KEY=

# Optional. Clerk userId of the org owner the MCP server should act on behalf
# of. If unset, falls back to the first org in the database.
MCP_USER_ID=

# --- OpenAI (semantic search embeddings) ---
# Optional. Without it, search falls back to text matching.
OPENAI_API_KEY=

# --- Anthropic (in-platform Claude chat) ---
# Optional. Without it, the chat panel returns a 500 with a setup hint.
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-5.
ANTHROPIC_MODEL_ID=

# --- Composio (external app tools, via universal MCP) ---
# Optional. Paste the **consumer API key** (`ck_...`) from Composio's
# "For You" dashboard → Settings → Sessions. This authenticates the
# chat as an MCP client of your account, exposing all your connected
# Gmail / Calendar / Drive / Notion / etc. with per-call account
# routing via the meta-tools surface. When unset, the chat falls back
# to platform-only tools without erroring.
COMPOSIO_CONSUMER_API_KEY=
# Optional override; defaults to https://connect.composio.dev/mcp.
COMPOSIO_MCP_URL=
